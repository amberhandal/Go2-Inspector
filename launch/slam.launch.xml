<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="use_rviz" default="true"/>
  <arg name="use_slam" default="true"/>
  <arg name="rviz_config" default="$(find-pkg-share go2_navigation)/config/slam_view.rviz"/>

  <!-- Path to URDF -->
  <let name="urdf_file"
       value="$(find-pkg-share go2_navigation)/urdf/go2_navigation.urdf.xacro"/>

  <!-- Robot State Publisher -->
  <node pkg="robot_state_publisher"
        exec="robot_state_publisher"
        name="robot_state_publisher"
        output="screen">
    <param name="robot_description"
           value="$(command 'xacro $(var urdf_file)')"/>
    <param name="publish_frequency" value="100.0"/>
  </node>

  <!-- Joint State Bridge -->
  <node pkg="go2_navigation"
        exec="joint_state_bridge"
        name="joint_state_bridge"
        output="screen">
    <param name="lowstate_topic" value="/lowstate"/>
    <param name="joint_states_topic" value="/joint_states"/>
  </node>

  <!-- Odom TF Bridge -->
  <node pkg="go2_navigation"
        exec="odom_tf_bridge"
        name="odom_tf_bridge"
        output="screen">
    <param name="odom_topic" value="/utlidar/robot_odom"/>
    <param name="odom_frame" value="odom"/>
    <param name="base_frame" value="base_link"/>
  </node>

  <!-- Static transform: base_link -> utlidar_lidar -->
  <node pkg="tf2_ros"
        exec="static_transform_publisher"
        name="base_to_lidar_tf"
        output="screen">
    <param name="frame_id" value="base_link"/>
    <param name="child_frame_id" value="utlidar_lidar"/>
    <param name="translation.x" value="0.28945"/>
    <param name="translation.y" value="0.0"/>
    <param name="translation.z" value="-0.046825"/>
    <param name="rotation.x" value="0.0"/>
    <param name="rotation.y" value="0.0"/>
    <param name="rotation.z" value="0.0"/>
    <param name="rotation.w" value="1.0"/>
  </node>

  <!-- PointCloud to LaserScan converter -->
  <node pkg="go2_navigation"
        exec="pointcloud_to_scan"
        name="pointcloud_to_scan"
        output="screen">
    <param name="cloud_topic" value="/utlidar/cloud"/>
    <param name="scan_topic" value="/scan"/>
    <param name="scan_frame" value="utlidar_lidar"/>
    <param name="min_height" value="-0.1"/>
    <param name="max_height" value="0.5"/>
    <param name="range_min" value="0.15"/>
    <param name="range_max" value="25.0"/>
  </node>

  <!-- SLAM Toolbox -->
  <node pkg="slam_toolbox"
        exec="async_slam_toolbox_node"
        name="slam_toolbox"
        output="screen"
        if="$(var use_slam)">
    <param name="solver_plugin" value="solver_plugins::CeresSolver"/>
    <param name="ceres_linear_solver" value="SPARSE_NORMAL_CHOLESKY"/>
    <param name="ceres_preconditioner" value="SCHUR_JACOBI"/>
    <param name="ceres_trust_strategy" value="LEVENBERG_MARQUARDT"/>
    <param name="ceres_dogleg_type" value="TRADITIONAL_DOGLEG"/>
    <param name="ceres_loss_function" value="None"/>

    <param name="odom_frame" value="odom"/>
    <param name="map_frame" value="map"/>
    <param name="base_frame" value="base_link"/>
    <param name="scan_topic" value="/scan"/>
    
    <param name="mode" value="mapping"/>
    <param name="debug_logging" value="false"/>
    <param name="throttle_scans" value="1"/>
    <param name="transform_publish_period" value="0.02"/>
    <param name="map_update_interval" value="5.0"/>
    <param name="resolution" value="0.05"/>
    <param name="max_laser_range" value="25.0"/>
    <param name="minimum_time_interval" value="0.5"/>
    <param name="transform_timeout" value="0.2"/>
    <param name="tf_buffer_duration" value="30.0"/>
    <param name="stack_size_to_use" value="40000000"/>
    <param name="enable_interactive_mode" value="true"/>

    <param name="use_scan_matching" value="true"/>
    <param name="use_scan_barycenter" value="true"/>
    <param name="minimum_travel_distance" value="0.3"/>
    <param name="minimum_travel_heading" value="0.3"/>
    <param name="scan_buffer_size" value="10"/>
    <param name="scan_buffer_maximum_scan_distance" value="10.0"/>
    <param name="link_match_minimum_response_fine" value="0.1"/>
    <param name="link_scan_maximum_distance" value="1.5"/>
    <param name="loop_search_maximum_distance" value="3.0"/>
    <param name="do_loop_closing" value="true"/>
    <param name="loop_match_minimum_chain_size" value="10"/>
    <param name="loop_match_maximum_variance_coarse" value="3.0"/>
    <param name="loop_match_minimum_response_coarse" value="0.35"/>
    <param name="loop_match_minimum_response_fine" value="0.45"/>

    <param name="correlation_search_space_dimension" value="0.5"/>
    <param name="correlation_search_space_resolution" value="0.01"/>
    <param name="correlation_search_space_smear_deviation" value="0.1"/>

    <param name="loop_search_space_dimension" value="8.0"/>
    <param name="loop_search_space_resolution" value="0.05"/>
    <param name="loop_search_space_smear_deviation" value="0.03"/>

    <param name="distance_variance_penalty" value="0.5"/>
    <param name="angle_variance_penalty" value="1.0"/>
    <param name="fine_search_angle_offset" value="0.00349"/>
    <param name="coarse_search_angle_offset" value="0.349"/>
    <param name="coarse_angle_resolution" value="0.0349"/>
  </node>

  <!-- RViz2 -->
  <node pkg="rviz2"
        exec="rviz2"
        name="rviz2"
        output="screen"
        if="$(var use_rviz)">
    <param name="config_file" value="$(var rviz_config)"/>
  </node>
</launch>